"use client";

import React, { Suspense } from "react";
import { useParams, useRouter, useSearchParams } from "next/navigation";
import { Icon } from "@/components/ui/Icon";
import { Sidebar } from "@/components/layout/Sidebar";
import { Topbar } from "@/components/layout/Topbar";
import { getChatHistory, sendChatMessage, finalizeSession } from "@/lib/api";
import type { ChatMessage } from "@/types/index";

function formatParamKey(key: string): string {
  return key
    .replace(/_/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

function formatParamValue(value: unknown): string {
  if (Array.isArray(value)) return value.join(", ");
  if (typeof value === "object" && value !== null) return JSON.stringify(value);
  return String(value);
}

function WizardPage() {
  const { id } = useParams<{ id: string }>();
  const router = useRouter();
  const searchParams = useSearchParams();
  const initialMsg = searchParams.get("msg") ?? "";
  const sentInitial = React.useRef(false);

  const [messages, setMessages] = React.useState<ChatMessage[]>([]);
  const [extractedParams, setExtractedParams] = React.useState<Record<string, unknown>>({});
  const [input, setInput] = React.useState("");
  const [loading, setLoading] = React.useState(true);
  const [streaming, setStreaming] = React.useState(false);
  const [error, setError] = React.useState<string | null>(null);
  const [launching, setLaunching] = React.useState(false);

  const bottomRef = React.useRef<HTMLDivElement>(null);
  const inputRef = React.useRef<HTMLTextAreaElement>(null);

  // Auto-scroll to bottom when messages change
  React.useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  const loadHistory = React.useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const data = await getChatHistory(id);
      setMessages(data.chat_history);
      setExtractedParams(data.extracted_params ?? {});
    } catch (e) {
      setError(e instanceof Error ? e.message : "Failed to load chat history");
    } finally {
      setLoading(false);
    }
  }, [id]);

  React.useEffect(() => {
    loadHistory();
  }, [loadHistory]);

  // Auto-send the initial message from the ?msg= query param once history loads
  React.useEffect(() => {
    if (!loading && !error && initialMsg && !sentInitial.current && messages.length === 1) {
      sentInitial.current = true;
      setInput(initialMsg);
      // Use a microtask so setInput renders before handleSend reads state
      Promise.resolve().then(() => handleSend(initialMsg));
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [loading, error, initialMsg, messages.length]);

  const handleSend = async (overrideMsg?: string) => {
    const text = (overrideMsg ?? input).trim();
    if (!text || streaming) return;
    setInput("");

    // Immediately add user message
    const userMsg: ChatMessage = { role: "user", content: text };
    setMessages((prev) => [...prev, userMsg]);

    // Add placeholder assistant message
    const assistantPlaceholder: ChatMessage = { role: "assistant", content: "" };
    setMessages((prev) => [...prev, assistantPlaceholder]);
    setStreaming(true);

    try {
      for await (const event of sendChatMessage(id, text)) {
        if (event.type === "token" && event.content) {
          setMessages((prev) => {
            const updated = [...prev];
            const last = updated[updated.length - 1];
            if (last.role === "assistant") {
              updated[updated.length - 1] = {
                ...last,
                content: last.content + event.content,
              };
            }
            return updated;
          });
        } else if (event.type === "done") {
          if (event.extracted_params) {
            setExtractedParams(event.extracted_params);
          }
        }
      }
    } catch (e) {
      setMessages((prev) => {
        const updated = [...prev];
        const last = updated[updated.length - 1];
        if (last.role === "assistant" && last.content === "") {
          updated[updated.length - 1] = {
            ...last,
            content: "Sorry, something went wrong. Please try again.",
          };
        }
        return updated;
      });
    } finally {
      setStreaming(false);
      inputRef.current?.focus();
    }
  };

  const handleKeyDown = (e: React.KeyboardEvent<HTMLTextAreaElement>) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  };

  const handleLaunch = async () => {
    setLaunching(true);
    try {
      await finalizeSession(id, extractedParams);
      router.push(`/campaign/${id}/processing`);
    } catch (e) {
      setError(e instanceof Error ? e.message : "Failed to launch campaign");
      setLaunching(false);
    }
  };

  const hasEnoughParams = Object.keys(extractedParams).length >= 2;
  const paramEntries = Object.entries(extractedParams);

  return (
    <div className="shell">
      <Sidebar active="new" />
      <div className="main">
        <Topbar
          crumb={
            <>
              <span className="muted">New campaign</span>
              <Icon name="chev_r" size={11} className="sep" style={{ color: "var(--fg-3)" }} />
              <span>Campaign setup</span>
              <span className="badge b-draft" style={{ marginLeft: 8 }}>
                <span className="badge-dot" />Chat
              </span>
            </>
          }
          right={
            <>
              {hasEnoughParams && (
                <button
                  className="btn btn-primary btn-sm"
                  onClick={handleLaunch}
                  disabled={launching}
                  style={{ opacity: launching ? 0.6 : 1 }}
                >
                  <Icon name="sparkles" size={12} />
                  {launching ? "Launching…" : "Launch campaign →"}
                </button>
              )}
            </>
          }
        />

        <div style={{ display: "flex", flex: 1, minHeight: 0 }}>
          {/* Chat column */}
          <div style={{ flex: 1, display: "flex", flexDirection: "column", minWidth: 0 }}>
            {loading ? (
              <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center", flexDirection: "column", gap: 12 }}>
                <div style={{
                  width: 28,
                  height: 28,
                  borderRadius: "50%",
                  border: "2px solid var(--border-strong)",
                  borderTopColor: "var(--accent)",
                  animation: "spin 0.8s linear infinite",
                }} />
                <span style={{ fontSize: 12, color: "var(--fg-3)" }}>Loading conversation…</span>
              </div>
            ) : error ? (
              <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center", flexDirection: "column", gap: 12, padding: 24 }}>
                <div style={{ width: 36, height: 36, borderRadius: 8, background: "rgba(232,122,122,0.1)", display: "grid", placeItems: "center" }}>
                  <Icon name="warn" size={18} style={{ color: "var(--red)" }} />
                </div>
                <div style={{ fontSize: 13, color: "var(--fg-1)", textAlign: "center", maxWidth: 320 }}>{error}</div>
                <button className="btn btn-sm" onClick={loadHistory}>
                  <Icon name="refresh" size={12} />Retry
                </button>
              </div>
            ) : (
              <>
                {/* Messages */}
                <div style={{ flex: 1, overflow: "auto", padding: "20px 24px", display: "flex", flexDirection: "column", gap: 12 }}>
                  {messages.length === 0 && (
                    <div style={{ display: "flex", alignItems: "center", justifyContent: "center", flex: 1, color: "var(--fg-3)", fontSize: 13 }}>
                      Start a conversation to set up your campaign
                    </div>
                  )}
                  {messages.map((msg, i) => (
                    <div
                      key={i}
                      style={{
                        display: "flex",
                        justifyContent: msg.role === "user" ? "flex-end" : "flex-start",
                      }}
                    >
                      {msg.role === "assistant" && (
                        <div style={{
                          width: 22,
                          height: 22,
                          borderRadius: 6,
                          background: "var(--accent-dim)",
                          display: "grid",
                          placeItems: "center",
                          flexShrink: 0,
                          marginRight: 8,
                          marginTop: 2,
                        }}>
                          <Icon name="sparkles" size={12} style={{ color: "var(--accent)" }} />
                        </div>
                      )}
                      <div
                        style={{
                          maxWidth: "72%",
                          padding: "10px 14px",
                          borderRadius: msg.role === "user" ? "12px 12px 4px 12px" : "4px 12px 12px 12px",
                          background: msg.role === "user" ? "var(--bg-1)" : "var(--accent-dim)",
                          border: `0.5px solid ${msg.role === "user" ? "var(--border-strong)" : "rgba(125,211,160,0.2)"}`,
                          fontSize: 13,
                          lineHeight: 1.6,
                          color: "var(--fg)",
                          whiteSpace: "pre-wrap",
                          wordBreak: "break-word",
                          position: "relative",
                        }}
                      >
                        {msg.content}
                        {msg.role === "assistant" && msg.content === "" && streaming && i === messages.length - 1 && (
                          <span style={{
                            display: "inline-block",
                            width: 8,
                            height: 14,
                            background: "var(--accent)",
                            marginLeft: 2,
                            borderRadius: 2,
                            verticalAlign: "text-bottom",
                            animation: "blink 1s step-end infinite",
                          }} />
                        )}
                        {msg.role === "assistant" && msg.content !== "" && streaming && i === messages.length - 1 && (
                          <span style={{
                            display: "inline-block",
                            width: 8,
                            height: 14,
                            background: "var(--accent)",
                            marginLeft: 2,
                            borderRadius: 2,
                            verticalAlign: "text-bottom",
                            opacity: 0.8,
                            animation: "blink 1s step-end infinite",
                          }} />
                        )}
                      </div>
                    </div>
                  ))}
                  <div ref={bottomRef} />
                </div>

                {/* Input area */}
                <div style={{ padding: "12px 24px 16px", borderTop: "0.5px solid var(--border)", flexShrink: 0 }}>
                  <div style={{
                    display: "flex",
                    gap: 8,
                    alignItems: "flex-end",
                    background: "var(--bg-1)",
                    border: "0.5px solid var(--border-strong)",
                    borderRadius: 10,
                    padding: "10px 12px",
                  }}>
                    <textarea
                      ref={inputRef}
                      className="field"
                      value={input}
                      onChange={(e) => setInput(e.target.value)}
                      onKeyDown={handleKeyDown}
                      placeholder="Message the AI assistant… (Enter to send, Shift+Enter for new line)"
                      rows={1}
                      disabled={streaming}
                      style={{
                        flex: 1,
                        resize: "none",
                        border: "none",
                        background: "transparent",
                        padding: 0,
                        outline: "none",
                        fontSize: 13,
                        lineHeight: 1.5,
                        minHeight: 20,
                        maxHeight: 120,
                        overflow: "auto",
                        color: "var(--fg)",
                      }}
                    />
                    <button
                      className="btn btn-primary btn-sm"
                      onClick={() => handleSend()}
                      disabled={!input.trim() || streaming}
                      style={{
                        flexShrink: 0,
                        opacity: !input.trim() || streaming ? 0.5 : 1,
                        height: 32,
                        alignSelf: "flex-end",
                      }}
                    >
                      <Icon name="send" size={13} />
                      Send
                    </button>
                  </div>
                  <div style={{ marginTop: 6, fontSize: 10.5, color: "var(--fg-3)", textAlign: "center" }}>
                    AI will ask questions to build your campaign — answer naturally
                  </div>
                </div>
              </>
            )}
          </div>

          {/* Extracted params panel */}
          <div style={{
            width: 280,
            borderLeft: "0.5px solid var(--border)",
            display: "flex",
            flexDirection: "column",
            flexShrink: 0,
          }}>
            <div style={{
              padding: "12px 16px",
              borderBottom: "0.5px solid var(--border)",
              display: "flex",
              alignItems: "center",
              gap: 8,
            }}>
              <Icon name="layers" size={13} style={{ color: "var(--fg-3)" }} />
              <span style={{ fontSize: 11.5, fontWeight: 550, letterSpacing: "0.04em" }}>Extracted parameters</span>
              {paramEntries.length > 0 && (
                <span style={{
                  marginLeft: "auto",
                  fontSize: 10,
                  fontWeight: 600,
                  fontFamily: "var(--font-mono)",
                  background: "var(--accent-dim)",
                  color: "var(--accent)",
                  padding: "2px 6px",
                  borderRadius: 10,
                }}>
                  {paramEntries.length}
                </span>
              )}
            </div>

            <div style={{ flex: 1, overflow: "auto", padding: 16 }}>
              {paramEntries.length === 0 ? (
                <div style={{
                  display: "flex",
                  flexDirection: "column",
                  alignItems: "center",
                  justifyContent: "center",
                  gap: 10,
                  height: "100%",
                  minHeight: 160,
                  textAlign: "center",
                }}>
                  <div style={{
                    width: 36,
                    height: 36,
                    borderRadius: 8,
                    background: "var(--bg-1)",
                    border: "0.5px solid var(--border)",
                    display: "grid",
                    placeItems: "center",
                  }}>
                    <Icon name="sparkles" size={16} style={{ color: "var(--fg-3)" }} />
                  </div>
                  <div style={{ fontSize: 12, color: "var(--fg-3)", lineHeight: 1.5 }}>
                    Chat with the AI to build your campaign
                  </div>
                </div>
              ) : (
                <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                  {paramEntries.map(([key, value]) => (
                    <div key={key} style={{
                      background: "var(--bg-1)",
                      border: "0.5px solid var(--border)",
                      borderRadius: 8,
                      padding: "8px 10px",
                    }}>
                      <div style={{
                        fontSize: 10.5,
                        fontWeight: 500,
                        letterSpacing: "0.04em",
                        color: "var(--fg-3)",
                        marginBottom: 4,
                        textTransform: "uppercase",
                      }}>
                        {formatParamKey(key)}
                      </div>
                      <div style={{
                        fontSize: 12,
                        color: "var(--fg-1)",
                        lineHeight: 1.5,
                        wordBreak: "break-word",
                      }}>
                        {formatParamValue(value)}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>

            {hasEnoughParams && (
              <div style={{ padding: 16, borderTop: "0.5px solid var(--border)", flexShrink: 0 }}>
                <button
                  className="btn btn-primary btn-sm"
                  onClick={handleLaunch}
                  disabled={launching}
                  style={{ width: "100%", justifyContent: "center", opacity: launching ? 0.6 : 1 }}
                >
                  <Icon name="sparkles" size={12} />
                  {launching ? "Launching…" : "Launch campaign →"}
                </button>
                <div style={{ marginTop: 8, fontSize: 10.5, color: "var(--fg-3)", textAlign: "center", lineHeight: 1.4 }}>
                  {paramEntries.length} params extracted · ready to launch
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
      `}</style>
    </div>
  );
}

export default function WizardPageWrapper() {
  return (
    <Suspense
      fallback={
        <div
          style={{
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            height: "100vh",
            flexDirection: "column",
            gap: 12,
          }}
        >
          <div
            style={{
              width: 28,
              height: 28,
              borderRadius: "50%",
              border: "2px solid var(--border-strong)",
              borderTopColor: "var(--accent)",
              animation: "spin 0.8s linear infinite",
            }}
          />
          <span style={{ fontSize: 12, color: "var(--fg-3)" }}>Loading…</span>
          <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
        </div>
      }
    >
      <WizardPage />
    </Suspense>
  );
}
