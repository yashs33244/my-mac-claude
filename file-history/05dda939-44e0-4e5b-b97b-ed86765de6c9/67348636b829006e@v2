import pytest
import uuid
from app.models.campaign import Campaign
from app.models.campaign_session import CampaignSession
from app.models.contact import Contact
from app.models.email_job import EmailJob


async def _seed(db_session, user, draft_status="approved", bounce_risk=False):
    c = Campaign(user_id=user.id, type="b2b", status="ready")
    db_session.add(c)
    await db_session.flush()

    db_session.add(CampaignSession(campaign_id=c.id, status="completed", chat_history=[], extracted_params={}))

    contact = Contact(
        campaign_id=c.id,
        company="Acme",
        person_name="Bob",
        email="bob@acme.com",
        title="CEO",
        source="apollo",
        bounce_risk=bounce_risk,
    )
    db_session.add(contact)
    await db_session.flush()

    job = EmailJob(
        campaign_id=c.id,
        contact_id=contact.id,
        subject="Subject",
        body="Body",
        draft_status=draft_status,
        status="draft",
    )
    db_session.add(job)
    await db_session.flush()

    return c, contact, job


async def test_enqueue_approved_jobs(client, db_session, test_user):
    campaign, contact, job = await _seed(db_session, test_user, draft_status="approved")
    resp = await client.post(
        f"/api/v1/campaigns/{campaign.id}/email-jobs",
        json={"outreach_ids": "all"},
    )
    assert resp.status_code == 202
    data = resp.json()
    assert data["queued"] == 1
    assert data["skipped_bounced"] == 0


async def test_skips_bounced_contacts(client, db_session, test_user):
    campaign, contact, job = await _seed(db_session, test_user, draft_status="approved", bounce_risk=True)
    resp = await client.post(
        f"/api/v1/campaigns/{campaign.id}/email-jobs",
        json={"outreach_ids": "all"},
    )
    assert resp.status_code == 202
    data = resp.json()
    assert data["queued"] == 0
    assert data["skipped_bounced"] == 1


async def test_list_email_jobs(client, db_session, test_user):
    campaign, contact, job = await _seed(db_session, test_user)
    resp = await client.get(f"/api/v1/campaigns/{campaign.id}/email-jobs")
    assert resp.status_code == 200
    data = resp.json()
    assert data["total"] == 1
    assert data["jobs"][0]["contact_email"] == "bob@acme.com"
