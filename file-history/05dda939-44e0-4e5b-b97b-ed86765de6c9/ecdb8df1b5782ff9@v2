import sys
import os
import subprocess
import uvicorn

HOST = "0.0.0.0"
PORT = 8000
RELOAD = True
LOG_LEVEL = "info"

if __name__ == "__main__":
    # Derive the alembic binary path from the running Python's bin dir
    bin_dir = os.path.dirname(sys.executable)
    alembic_bin = os.path.join(bin_dir, "alembic")

    subprocess.run([alembic_bin, "upgrade", "head"], check=True)

    uvicorn.run(
        "app.main:app",
        host=HOST,
        port=PORT,
        reload=RELOAD,
        log_level=LOG_LEVEL,
    )
