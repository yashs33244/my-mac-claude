## 6. Database Schema

### Table: `users`

```sql
CREATE TABLE users (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email           TEXT NOT NULL UNIQUE,
    hashed_password TEXT,                          -- null if Google OAuth only
    google_id       TEXT UNIQUE,
    gmail_oauth_token JSONB,                       -- {access_token, refresh_token, expiry}
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
```

### Table: `user_profiles`

```sql
CREATE TABLE user_profiles (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    linkedin_url    TEXT,
    twitter_url     TEXT,
    portfolio_url   TEXT,
    resume_url      TEXT,                          -- Google Drive file URL
    experience_level TEXT,                         -- fresher | junior | mid | senior | lead
    bio             TEXT,
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE UNIQUE INDEX idx_user_profiles_user_id ON user_profiles(user_id);
```

### Table: `settings`

```sql
CREATE TABLE settings (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    email_source    TEXT NOT NULL DEFAULT 'apollo',  -- apollo | scrape
    llm_provider    TEXT NOT NULL DEFAULT 'openai',  -- openai | anthropic | gemini
    llm_model       TEXT NOT NULL DEFAULT 'gpt-4o',
    email_provider  TEXT NOT NULL DEFAULT 'gmail',   -- gmail | sendgrid (v2)
    sendgrid_api_key TEXT,                           -- user-supplied, encrypted at rest
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE UNIQUE INDEX idx_settings_user_id ON settings(user_id);
```

### Table: `campaigns`

```sql
CREATE TABLE campaigns (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    type            TEXT NOT NULL,              -- job_outreach | b2b | hiring | pr | fundraising | partnership
    status          TEXT NOT NULL DEFAULT 'draft',  -- draft | processing | ready | sending | done | failed
    config_json     JSONB NOT NULL DEFAULT '{}',    -- target_companies, geography, intent, etc.
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
CREATE INDEX idx_campaigns_user_id ON campaigns(user_id);
CREATE INDEX idx_campaigns_status ON campaigns(status);
```

**`config_json` shape:**
```json
{
  "intent": "I want to get a backend engineering role at Series B startups",
  "target_companies": ["Stripe", "Linear", "Vercel"],
  "geography": ["US", "India"],
  "email_source": "apollo",
  "llm_provider": "openai",
  "llm_model": "gpt-4o"
}
```

### Table: `campaign_sessions`

```sql
CREATE TABLE campaign_sessions (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    campaign_id     UUID NOT NULL REFERENCES campaigns(id) ON DELETE CASCADE,
    chat_history    JSONB NOT NULL DEFAULT '[]',    -- [{role, content}] array
    extracted_params JSONB NOT NULL DEFAULT '{}',   -- structured params parsed from chat
    status          TEXT NOT NULL DEFAULT 'active', -- active | completed
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
