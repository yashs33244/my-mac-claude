# ─── XLSX EXPORT ───────────────────────────────────────────────────────────

def build_xlsx(contacts, output_path):
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Batch 1 Outreach"

    # Colors
    HEADER_FILL   = PatternFill(start_color="1F3864", end_color="1F3864", fill_type="solid")
    HEADER_FONT   = Font(bold=True, color="FFFFFF", size=11)
    PENDING_FILL  = PatternFill(start_color="FFF2CC", end_color="FFF2CC", fill_type="solid")
    SENT_FILL     = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")
    FAILED_FILL   = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")

    # Sector badge colors
    SECTOR_COLORS = {
        "Retail":        "FCE4D6",
        "Manufacturing": "DDEBF7",
        "IT/Tech":       "E2EFDA",
        "Banking":       "EDE7F6",
        "Healthcare":    "FCE4EC",
        "Real Estate":   "FFF9C4",
        "Logistics":     "E0F7FA",
        "Hospitality":   "F3E5F5",
    }

    COLS = ["#", "Name", "Title", "Company", "City", "Sector",
            "Email", "Subject", "Email Body", "Status",
            "Sent At", "Opened", "Replied", "LinkedIn"]

    COL_WIDTHS = {
        "#": 5, "Name": 22, "Title": 28, "Company": 30, "City": 14,
        "Sector": 15, "Email": 35, "Subject": 45, "Email Body": 80,
        "Status": 12, "Sent At": 18, "Opened": 10, "Replied": 10, "LinkedIn": 40
    }

    # Header row
    for col_idx, col_name in enumerate(COLS, 1):
        cell = ws.cell(row=1, column=col_idx, value=col_name)
        cell.fill = HEADER_FILL
        cell.font = HEADER_FONT
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=False)

    ws.row_dimensions[1].height = 30
    ws.freeze_panes = "A2"
    ws.auto_filter.ref = f"A1:{get_column_letter(len(COLS))}1"

    # Data rows
    for row_idx, c in enumerate(contacts, 2):
        status = c.get("status", "pending")
        fill = PENDING_FILL if status == "pending" else (SENT_FILL if status == "sent" else FAILED_FILL)
        sector_fill = PatternFill(
            start_color=SECTOR_COLORS.get(c["sector"], "FFFFFF"),
            end_color=SECTOR_COLORS.get(c["sector"], "FFFFFF"),
            fill_type="solid"
        )

        row_data = [
            row_idx - 1, c["name"], c["title"], c["company"], c["city"],
            c["sector"], c["email"], c["subject"], c["body"],
            c["status"], c["sent_at"], c["opened"], c["replied"], c["linkedin_url"]
        ]

        for col_idx, value in enumerate(row_data, 1):
            cell = ws.cell(row=row_idx, column=col_idx, value=value)
            col_name = COLS[col_idx - 1]
            # Sector column gets sector color, rest get status color
            if col_name == "Sector":
                cell.fill = sector_fill
                cell.font = Font(bold=True, size=10)
            else:
                cell.fill = fill
            if col_name == "Email Body":
                cell.alignment = Alignment(wrap_text=True, vertical="top")
            else:
                cell.alignment = Alignment(vertical="center", wrap_text=False)
            # Row height for email body
        ws.row_dimensions[row_idx].height = 80

    # Column widths
    for col_idx, col_name in enumerate(COLS, 1):
        ws.column_dimensions[get_column_letter(col_idx)].width = COL_WIDTHS[col_name]

    # Legend sheet
    ls = wb.create_sheet("Legend")
    ls.column_dimensions["A"].width = 25
    ls.column_dimensions["B"].width = 40

    legend = [
        ("Color", "Meaning"),
        ("Yellow row", "Pending — not sent yet"),
        ("Green row", "Sent successfully"),
        ("Red row", "Failed to send"),
        ("Sector column color", "Identifies industry segment"),
    ]
    for r, (a, b) in enumerate(legend, 1):
        ls.cell(row=r, column=1, value=a).font = Font(bold=(r == 1))
        ls.cell(row=r, column=2, value=b).font = Font(bold=(r == 1))

    wb.save(output_path)
    print(f"✓ Saved: {output_path}")
    return output_path

